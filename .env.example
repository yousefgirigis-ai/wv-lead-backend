# ─── Meta / Facebook ───────────────────────────────────────────
# Get these from https://developers.facebook.com → Your App → Settings
META_VERIFY_TOKEN=my_random_secret_string_123
META_APP_SECRET=your_meta_app_secret_here
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
META_PAGE_ID=your_facebook_page_id_here

# ─── MongoDB ───────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/leads
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/leads
# MONGODB_URI=mongodb://localhost:27017/leads

# ─── App ───────────────────────────────────────────────────────
PORT=3001

# ─── Polling (optional — only if NOT using webhooks) ───────────
# How often to check for new messages (milliseconds)
# 60000 = every 1 minute
POLL_INTERVAL_MS=60000
